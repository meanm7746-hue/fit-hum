
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Fit Hub - Mens Wear</title>
<style>
body{
margin:0;
font-family:Arial,sans-serif;
background:#f1f3f6;
}
header{
background:#2874f0;
color:white;
padding:15px;
text-align:center;
font-size:28px;
font-weight:bold;
}
.banner{
background:white;
margin:10px;
padding:20px;
text-align:center;
border-radius:10px;
font-size:24px;
font-weight:bold;
color:#2874f0;
}
.banner span{
color:#ff6600;
}
.products{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(180px,1fr));
gap:15px;
padding:15px;
}
.card{
background:white;
padding:15px;
border-radius:10px;
text-align:center;
box-shadow:0 2px 5px rgba(0,0,0,0.1);
}
.card img{
width:100%;
height:180px;
object-fit:cover;
border-radius:8px;
}
.card h3{
margin:10px 0 5px;
font-size:18px;
}
.price{
color:green;
font-weight:bold;
font-size:18px;
}
button{
background:#2874f0;
color:white;
border:none;
padding:10px 15px;
border-radius:6px;
cursor:pointer;
margin-top:10px;
font-size:16px;
}
button:hover{
background:#1259c3;
}
footer{
background:white;
padding:15px;
text-align:center;
margin-top:20px;
font-size:16px;
}
</style>
</head>
<body>

<header>Fit Hub</header>

<div class="banner">
🔥 Big Sale <span>Up to 50% OFF</span><br>
Free Delivery in Malappuram
</div>

<div class="products">

<div class="card">
<img src="https://images.unsplash.com/photo-1602810318383-e386cc2a3ccf" alt="">
<h3>Black Shirt</h3>
<p class="price">₹799</p>
<button onclick="order('Black Shirt')">Order Now</button>
</div>

<div class="card">
<img src="https://images.unsplash.com/photo-1521572267360-ee0c2909d518" alt="">
<h3>White T-Shirt</h3>
<p class="price">₹599</p>
<button onclick="order('White T-Shirt')">Order Now</button>
</div>

<div class="card">
<img src="https://images.unsplash.com/photo-1541099649105-f69ad21f3246" alt="">
<h3>Blue Jeans</h3>
<p class="price">₹1299</p>
<button onclick="order('Blue Jeans')">Order Now</button>
</div>

<div class="card">
<img src="https://images.unsplash.com/photo-1600185365483-26d7a4cc7519" alt="">
<h3>Sneakers</h3>
<p class="price">₹1499</p>
<button onclick="order('Sneakers')">Order Now</button>
</div>

</div>

<footer>
WhatsApp Orders: +91 77367 89255
</footer>

<script>
function order(product){
let msg = "Hello Fit Hub, I want to order " + product;
window.open("https://wa.me/917736789255?text=" + encodeURIComponent(msg),"_blank");
}
</script>

</body>
</html>
